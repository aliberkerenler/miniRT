# Test: Birden fazla silindir - farklı yönelimler
# Kamera önden bakıyor

A 0.2 255,255,255

C 0,0,15 0,0,-1 80

L 8,8,10 0.7 255,255,255

# Dikey silindir (Y ekseni)
